# ================================================================
# LLM Backend
# ================================================================
# Choose: 'claude' or 'codex'
LLM_BACKEND=claude

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-opus-4-6

# OpenAI (Codex/GPT-4o)
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o

# ================================================================
# PostgreSQL
# ================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=freqtrade_agent
POSTGRES_USER=agent
POSTGRES_PASSWORD=changeme

# ================================================================
# Redis (task queue)
# ================================================================
REDIS_URL=redis://redis:6379/0

# ================================================================
# Freqtrade
# ================================================================
FREQTRADE_CONFIG=/freqtrade/config.json
FREQTRADE_DATA_DIR=/freqtrade/user_data/data
FREQTRADE_STRATEGY_DIR=/freqtrade/user_data/strategies
FREQTRADE_RESULTS_DIR=/freqtrade/user_data/backtest_results

# ================================================================
# Backtest Universe
# What the agent is ALLOWED to test. Data must exist on disk
# for all pairs x timeframes listed here before running.
# Comma-separated, no spaces.
# ================================================================
BACKTEST_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,ADA/USDT
BACKTEST_TIMEFRAMES=1h,4h,1d

# ================================================================
# Date Windows
# Set these ONCE before the first run and never change them.
# Changing the holdout window after the first experiment
# invalidates your out-of-sample results.
#
# in_sample: data the agent optimizes against
# holdout:   sacred ground-truth, evaluated last and never tuned on
# ================================================================
IN_SAMPLE_START=2021-01-01
IN_SAMPLE_END=2023-06-30
HOLDOUT_START=2023-07-01
HOLDOUT_END=2024-06-30

# ================================================================
# Walk-Forward Validation
# Rolls a window across the in-sample period to detect overfit.
# A strategy must pass walk_forward_min_pass_ratio of windows
# to be promoted to holdout evaluation.
# ================================================================
WALK_FORWARD_ENABLED=true
WALK_FORWARD_WINDOW_DAYS=180
WALK_FORWARD_STEP_DAYS=60
WALK_FORWARD_MIN_PASS_RATIO=0.6

# ================================================================
# Agent Scoring Thresholds
# ================================================================
MAX_DRAWDOWN_THRESHOLD=0.25
EXPLORE_MAX_DRAWDOWN_THRESHOLD=0.40
MIN_TRADE_COUNT=30
OOS_HOLDOUT_RATIO=0.2
INSIGHT_SYNTHESIS_EVERY=20
MAX_COMPONENTS_PER_STRATEGY=6

LOG_LEVEL=INFO
